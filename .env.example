# Optional LLM enhancement settings for RoadTripper.
# Leave this file as-is if you do not want LLM-backed narration.

# Choose one:
# ROADTRIPPER_LLM_PROVIDER=openrouter
# ROADTRIPPER_LLM_PROVIDER=openai

# Pick a model supported by that provider.
# ROADTRIPPER_LLM_MODEL=openai/gpt-5.4-mini

# Provide the matching API key.
# ROADTRIPPER_OPENROUTER_API_KEY=your_openrouter_key_here
# ROADTRIPPER_OPENAI_API_KEY=your_openai_api_key_here

# Optional dedicated TTS provider.
# ROADTRIPPER_TTS_PROVIDER=openai
# ROADTRIPPER_TTS_MODEL=tts-1-hd
# ROADTRIPPER_TTS_VOICE=sage

# Optional Plot Trip routing settings.
# Default uses OSRM Trip service for waypoint optimization.
# ROADTRIPPER_ROUTING_PROVIDER=osrm
# ROADTRIPPER_OSRM_URL=https://router.project-osrm.org

# OpenRouteService can be used for ordered waypoint routing.
# ROADTRIPPER_ROUTING_PROVIDER=openrouteservice
# ROADTRIPPER_ORS_API_KEY=your_openrouteservice_key_here

# Optional town gazetteer for comprehensive route-town selection.
# ROADTRIPPER_TOWN_DATA=/path/to/us_towns.json
